# The Antenna — Environment Configuration
# Copy this to .env and fill in your values

# ── Discord Bot (full two-way integration) ─────────────────────────
# Bot token from Discord Developer Portal
ANTENNA_BOT_TOKEN=

# Channel ID where digests and alerts get posted
# Right-click channel → Copy Channel ID (enable Developer Mode in Discord settings first)
ANTENNA_CHANNEL_ID=

# Your Discord user ID for critical alert DMs (optional)
# Right-click your name → Copy User ID
ANTENNA_LEAD_ID=

# ── Discord Webhook (simple one-way fallback) ─────────────────────
# Only needed if NOT using the bot
# ANTENNA_DISCORD_WEBHOOK=

# ── Tracked Teams (override default list) ──────────────────────────
# ANTENNA_TRACKED_TEAMS=254,118,1678,6328,3847,1323,2056,4414,2910,1690,1114,973,2826

# ── Scan Settings ─────────────────────────────────────────────────
# Max pages per scan (30 topics/page, default: 10)
# ANTENNA_MAX_PAGES=10

# Scan mode: normal, kickoff, build, competition, postseason
# ANTENNA_SCAN_MODE=normal
